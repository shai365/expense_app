// Hand-maintained Prisma schema. Source of truth for the database schema
// is backend/migrations/001_initial_schema.sql — keep this file in sync
// when migrations evolve. Prisma cannot represent RLS policies, partial
// indexes, triggers, or the auth.users FK, so those live only in SQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id              String    @id @default(uuid()) @db.Uuid
  kind            String
  displayName     String    @map("display_name")
  legalName       String?   @map("legal_name")
  taxId           String?   @map("tax_id")
  vatStatus       String?   @map("vat_status")
  country         String    @default("IL")
  defaultCurrency String    @default("ILS") @map("default_currency")
  settings        Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  memberships     Membership[]
  managerLinks    OrgLink[]    @relation("ManagerOrg")
  managedLinks    OrgLink[]    @relation("ManagedOrg")
  projects        Project[]
  receipts        Receipt[]
  scanJobs        ScanJob[]
  exportJobs      ExportJob[]
  defaultForUsers User[]

  @@index([kind])
  @@map("organizations")
}

// Profile table — id matches auth.users.id. Prisma cannot express the
// cross-schema FK to auth.users; that constraint lives in the SQL migration.
model User {
  id             String    @id @db.Uuid
  email          String?
  displayName    String?   @map("display_name")
  preferredLang  String    @default("he") @map("preferred_lang")
  defaultOrgId   String?   @map("default_org_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  defaultOrg      Organization? @relation(fields: [defaultOrgId], references: [id])
  memberships     Membership[]
  scanJobs        ScanJob[]
  exportJobs      ExportJob[]
  scannedReceipts Receipt[]     @relation("ScannedByUser")

  @@map("users")
}

model Membership {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  role      String
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
  @@map("memberships")
}

model OrgLink {
  id           String    @id @default(uuid()) @db.Uuid
  managerOrgId String    @map("manager_org_id") @db.Uuid
  managedOrgId String    @map("managed_org_id") @db.Uuid
  permissions  Json      @default("{\"read\":true,\"export\":true,\"write\":false}")
  startedAt    DateTime  @default(now()) @map("started_at") @db.Timestamptz
  endedAt      DateTime? @map("ended_at") @db.Timestamptz

  managerOrg Organization @relation("ManagerOrg", fields: [managerOrgId], references: [id], onDelete: Cascade)
  managedOrg Organization @relation("ManagedOrg", fields: [managedOrgId], references: [id], onDelete: Cascade)

  @@unique([managerOrgId, managedOrgId])
  @@map("org_links")
}

model Project {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  receipts Receipt[]

  @@unique([orgId, name])
  @@map("projects")
}

model VatRateHistory {
  id            String    @id @default(uuid()) @db.Uuid
  country       String    @default("IL")
  rate          Decimal   @db.Decimal(5, 4)
  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  sourceNote    String?   @map("source_note")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@unique([country, effectiveFrom])
  @@map("vat_rate_history")
}

model ScanJob {
  id             String    @id @default(uuid()) @db.Uuid
  orgId          String    @map("org_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  model          String
  status         String
  receiptCount   Int?      @map("receipt_count")
  imageObjectKey String?   @map("image_object_key")
  requestBytes   Int?      @map("request_bytes")
  responseBytes  Int?      @map("response_bytes")
  latencyMs      Int?      @map("latency_ms")
  errorCode      String?   @map("error_code")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  completedAt    DateTime? @map("completed_at") @db.Timestamptz

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id])
  receipts Receipt[]

  @@index([orgId, createdAt(sort: Desc)])
  @@map("scan_jobs")
}

model Receipt {
  id              String    @id @default(uuid()) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  scannedByUserId String?   @map("scanned_by_user_id") @db.Uuid
  invoiceNumber   String?   @map("invoice_number")
  receiptDate     DateTime? @map("receipt_date") @db.Date
  businessName    String?   @map("business_name")
  amount          Decimal?  @db.Decimal(12, 2)
  currency        String    @default("ILS")
  vatAmount       Decimal?  @map("vat_amount") @db.Decimal(12, 2)
  vatRate         Decimal?  @map("vat_rate") @db.Decimal(5, 4)
  vatSource       String?   @map("vat_source")
  startTime       DateTime? @map("start_time") @db.Time
  endTime         DateTime? @map("end_time") @db.Time
  projectId       String?   @map("project_id") @db.Uuid
  category        String?
  boundingBox     Json?     @map("bounding_box")
  confidence      Decimal?  @db.Decimal(3, 2)
  imageObjectKey  String?   @map("image_object_key")
  scanJobId       String?   @map("scan_job_id") @db.Uuid
  scannedAt       DateTime? @map("scanned_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  org           Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  scannedByUser User?         @relation("ScannedByUser", fields: [scannedByUserId], references: [id])
  project       Project?      @relation(fields: [projectId], references: [id])
  scanJob       ScanJob?      @relation(fields: [scanJobId], references: [id])
  items         ReceiptItem[]

  @@index([orgId, receiptDate])
  @@index([orgId, category])
  @@index([orgId, scannedAt(sort: Desc)])
  @@map("receipts")
}

model ReceiptItem {
  id          String   @id @default(uuid()) @db.Uuid
  receiptId   String   @map("receipt_id") @db.Uuid
  ord         Int
  code        String?
  description String?
  quantity    Decimal? @db.Decimal(10, 3)
  price       Decimal? @db.Decimal(12, 2)

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId, ord])
  @@map("receipt_items")
}

model ExportJob {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  format      String
  filters     Json?
  objectKey   String?   @map("object_key")
  status      String
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id])

  @@index([orgId, createdAt(sort: Desc)])
  @@map("export_jobs")
}
