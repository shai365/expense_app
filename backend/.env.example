# Copy to .env for local dev. Never commit the real .env.
# On Render / Cloud Run / etc., set these via the platform's env-var UI
# (or a Secret Manager binding) rather than baking them into the image.

PORT=8080
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# JWT signing key for /v1/sessions/exchange. Must be ≥32 chars.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_JWT_SECRET=

# Supabase Postgres. Get from Supabase dashboard → Settings → Database.
# Use the "Connection pooling" string (port 6543) in production;
# the direct connection (port 5432) is fine for local dev and migrations.
# For deployed environments without the CA cert file on disk, swap
#   sslmode=verify-full&sslrootcert=./prisma/supabase-ca.crt
# for just
#   sslmode=require
DATABASE_URL=

# Used only by `npm run seed`; runtime backend doesn't need it.
SUPABASE_SERVICE_ROLE_KEY=
