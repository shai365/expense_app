# Copy to .env for local dev. Never commit the real .env.
# In Cloud Run, inject GEMINI_API_KEY and DATABASE_URL from Secret Manager instead.

PORT=8080
GEMINI_API_KEY=

# Supabase Postgres. Get from Supabase dashboard → Settings → Database.
# Use the "Connection pooling" string (port 6543) in production for Cloud Run;
# the direct connection (port 5432) is fine for local dev and migrations.
DATABASE_URL=
